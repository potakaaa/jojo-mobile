# Public runtime config for the Expo client bundle.
# Only variables prefixed with EXPO_PUBLIC_ are inlined into the app —
# never put secrets here, they ship to every device.
# Copy this file to .env and adjust per environment (.env.development, .env.production, ...).

EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_URL=https://api.jojopotato.ph
