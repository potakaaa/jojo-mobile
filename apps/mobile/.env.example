# Public runtime config for the Expo client bundle.
# Only variables prefixed with EXPO_PUBLIC_ are inlined into the app —
# never put secrets here, they ship to every device. Auth secrets
# (BETTER_AUTH_SECRET, GOOGLE_CLIENT_SECRET, RESEND_API_KEY, ...) live ONLY in
# packages/api/.env — the app never needs them, it only needs the API base URL.
# Copy this file to .env and adjust per environment (.env.development, .env.production, ...).

EXPO_PUBLIC_APP_ENV=development
# Base URL of the packages/api server (better-auth is mounted at /api/auth).
# When running `pnpm dev` from the repo root, this is auto-overridden at runtime with
# the live ngrok tunnel URL (detected via ngrok's local admin API at 127.0.0.1:4040).
# The value below is only the fallback when no tunnel is detected (e.g. `expo start`
# directly, or dev:tunnel/ios/android/web). Use your machine's LAN IP instead of
# localhost when testing on a physical device without a tunnel.
EXPO_PUBLIC_API_URL=http://localhost:3000
# Feature flag: when 'true', the checkout screen enables the "Online payment"
# option. Default (unset/anything else) = false → pay-at-pickup only (CART-002).
EXPO_PUBLIC_ONLINE_PAYMENT_ENABLED=false
