{
  "name": "@jojopotato/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "eas-build-pre-install": "if [ -n \"$GOOGLE_SERVICES_JSON\" ]; then cp \"$GOOGLE_SERVICES_JSON\" ./android/app/google-services.json; fi",
    "start": "expo start",
    "dev": "node scripts/dev-with-tunnel.mjs",
    "dev:bypass": "node scripts/dev-bypass.mjs",
    "dev:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export",
    "lint": "eslint .",
    "guard:theme-mode": "node scripts/check-theme-mode.mjs",
    "guard:no-raw-alert": "node scripts/check-no-raw-alert.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests && jest",
    "clean": "rm -rf .expo dist node_modules",
    "build:ios:development:local": "npx eas-cli@latest build --platform ios --profile development --local --output ./builds/development/jojo-potato-development.ipa",
    "build:ios:preview:local": "npx eas-cli@latest build --platform ios --profile preview --local --output ./builds/preview/jojo-potato-preview.ipa",
    "build:ios:production:local": "npx eas-cli@latest build --platform ios --profile production --local --output ./builds/production/jojo-potato-production.ipa",
    "build:android:development:local": "npx eas-cli@latest build --platform android --profile development --local --output ./builds/development/jojo-potato-development.apk",
    "build:android:preview:local": "npx eas-cli@latest build --platform android --profile preview --local --output ./builds/preview/jojo-potato-preview.apk",
    "build:android:production:local": "npx eas-cli@latest build --platform android --profile production --local --output ./builds/production/jojo-potato-production.apk"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.23",
    "@expo-google-fonts/fredoka": "^0.4.1",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@jojopotato/types": "workspace:*",
    "@jojopotato/ui": "workspace:*",
    "@jojopotato/utils": "workspace:*",
    "@tanstack/react-query": "^5.62.0",
    "better-auth": "^1.6.23",
    "expo": "~57.0.4",
    "expo-application": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-dev-client": "^57.0.5",
    "expo-font": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-location": "~57.0.2",
    "expo-maps": "57.0.0",
    "expo-network": "~57.0.0",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@jest/globals": "^29.7.0",
    "@jojopotato/config": "workspace:*",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.1",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3",
    "vitest": "^3.2.4"
  }
}
