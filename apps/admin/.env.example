# Public runtime config for the apps/admin web client (Vite bundle).
# Only variables prefixed with VITE_ are inlined into the browser bundle —
# never put secrets here, they ship to every browser. Auth/DB secrets live ONLY
# in packages/api/.env; the admin app only needs the API base URL.
# Copy this file to .env and adjust per environment.

VITE_APP_ENV=development
# Base URL of the packages/api server (better-auth is mounted at /api/auth,
# admin routes at /api/admin — wired in Phase 1, not this scaffold phase).
VITE_API_URL=http://localhost:3000
