{
  "name": "jojo-potato",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev dev:ngrok",
    "dev:bypass": "turbo run dev:bypass",
    "dev:tunnel": "turbo run dev:tunnel",
    "start": "turbo run start",
    "ios": "turbo run ios --filter=@jojopotato/mobile",
    "android": "turbo run android --filter=@jojopotato/mobile",
    "web": "turbo run web --filter=@jojopotato/mobile",
    "mobile:ios:build:development:local": "pnpm --filter @jojopotato/mobile run build:ios:development:local",
    "mobile:ios:build:preview:local": "pnpm --filter @jojopotato/mobile run build:ios:preview:local",
    "mobile:ios:build:production:local": "pnpm --filter @jojopotato/mobile run build:ios:production:local",
    "mobile:android:build:development:local": "pnpm --filter @jojopotato/mobile run build:android:development:local",
    "mobile:android:build:preview:local": "pnpm --filter @jojopotato/mobile run build:android:preview:local",
    "mobile:android:build:production:local": "pnpm --filter @jojopotato/mobile run build:android:production:local",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "api": "turbo run dev --filter=@jojopotato/api",
    "db:generate": "turbo run db:generate --filter=@jojopotato/api",
    "db:migrate": "turbo run db:migrate --filter=@jojopotato/api",
    "db:seed": "turbo run db:seed --filter=@jojopotato/api",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@jojopotato/config": "workspace:*",
    "prettier": "^3.9.4",
    "turbo": "^2.10.4",
    "typescript": "~6.0.3"
  }
}
