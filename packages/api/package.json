    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "pg": "^8.16.3",
    "resend": "^6.17.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@jojopotato/config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.15.6",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.39.4",
    "tsx": "^4.20.6",
    "typescript": "~6.0.3",
    "vitest": "^3.2.4"
