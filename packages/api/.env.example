DATABASE_URL=postgres://jojo:jojo@localhost:5432/jojopotato
PORT=3000

# better-auth — ALL server-only. NEVER expose these to the mobile client / never
# prefix with EXPO_PUBLIC_ (that would ship them to every device).
# BETTER_AUTH_SECRET: generate with `openssl rand -base64 32`.
BETTER_AUTH_SECRET=
# BETTER_AUTH_URL: public base URL of this API (used to build OAuth callback and
# magic-link URLs). Local dev: http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# APP_SCHEME: the mobile app's deep-link scheme (apps/mobile/app.json `scheme`).
# Used by the /magic-link/native redirect route to bounce the magic-link token
# into the app. Server-only, no secret. Defaults to `jojopotato` if unset.
APP_SCHEME=jojopotato

# Google OAuth — provision a Google Cloud OAuth 2.0 client (MANUAL prerequisite,
# outside this repo's code scope). Authorized redirect URI:
# {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend — magic-link email delivery (MANUAL prerequisite: create a Resend
# account + API key). If unset, magic links are logged server-side instead of
# emailed (dev/test fallback).
RESEND_API_KEY=
# Optional verified sender; defaults to Resend's onboarding@resend.dev sandbox.
RESEND_FROM=

# DEV-ONLY auto-login — LOCAL DEVELOPMENT ONLY. Off unless DEV_AUTO_LOGIN=true.
# When on, it exposes POST /dev/session, which mints a real magic-link token for
# a SINGLE server-configured account so the app can skip the login screen in dev.
# It takes no parameters and can only ever sign in DEV_LOGIN_EMAIL — it cannot be
# pointed at another account by a caller.
# You normally do NOT set DEV_AUTO_LOGIN here at all — use `pnpm dev:bypass`,
# which sets it for one process only (and deliberately starts no ngrok tunnel, so
# the backdoor is never publicly reachable).
#   - DEV_LOGIN_EMAIL defaults to `dev@jojopotato.local`, is auto-created on first
#     use by better-auth's magicLink plugin, and is the ONLY account /dev/session
#     can ever sign in. If set, it must be a valid email (contain `@`) or the
#     server refuses to start.
#   - The server REFUSES TO START if DEV_AUTO_LOGIN=true while NODE_ENV=production.
# Leave both blank to keep auto-login off.
DEV_AUTO_LOGIN=
DEV_LOGIN_EMAIL=
